{
  "manifest_version": 3,
  "name": "Monitor de Bloqueos de Red",
  "version": "2.0.0",
  "description": "Shows OpenPath network blocks, helps request access, and checks local allowlist state without analytics or telemetry.",
  "author": "OpenPath System",
  "homepage_url": "https://github.com/balejosg/openpath",
  "developer": {
    "name": "OpenPath System",
    "url": "https://github.com/balejosg/openpath"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "openpath-block-monitor@openpath",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": ["browsingActivity"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "tabs",
    "clipboardWrite",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "scripts": ["dist/background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/page-activity-content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/page-resource-observer-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "default_title": "Monitor de Bloqueos"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
