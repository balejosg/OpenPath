{
  "googleSearchBlock": "*://www.google.*/search*",
  "googleGameBlocks": [
    "*://www.google.*/fbx?fbx=snake_arcade*",
    "*://doodles.google/*",
    "*://*.doodles.google/*",
    "*://www.google.*/logos/*"
